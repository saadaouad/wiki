{
  "name": "api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./server.ts",
  "scripts": {
    "dev": "tsx watch ./server.ts",
    "start": "node ./dist/server.js",
    "build": "tsup server.ts --format esm --out-dir dist",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx ./db/seed.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test:unit": "vitest run --config ../../packages/vitest-config/vitest.config.ts --project api-unit",
    "test:integration": "vitest run --config ../../packages/vitest-config/vitest.config.ts --project api-integration"
  },
  "dependencies": {
    "@epic-web/remember": "^1.1.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@repo/schema-validation": "*",
    "@upstash/redis": "^1.38.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "custom-env": "^2.0.6",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "4.0.1",
    "jose": "^6.2.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@repo/biome-config": "*",
    "@repo/typescript-config": "*",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "@types/supertest": "^6.0.3"
  }
}
