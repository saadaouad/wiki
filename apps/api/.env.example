# Database URL
DATABASE_URL=

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=

# Server Configuration
PORT=
HOST=

# Node Environment
APP_STAGE=
NODE_ENV=

# CORS Configuration
